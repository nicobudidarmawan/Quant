# Optional local LLM support.
# Quant runs without these variables. When disabled, Quant AI returns a
# deterministic local memo from the signal engine instead of calling a model.

# Enable local LLM calls.
QUANT_LLM_ENABLED=1

# OpenAI-compatible server base URL. The server should expose:
#   GET  /health
#   POST /v1/chat/completions
QUANT_LLM_BASE_URL=http://127.0.0.1:8080

# Model name sent to /v1/chat/completions.
QUANT_LLM_MODEL=gemma-4-e4b
